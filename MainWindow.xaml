                                Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="14" FontFamily="Segoe UI Emoji"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="DeleteMenuLabel" Text="Delete"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E53935" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>


            <Border x:Name="ContactProfileOverlay"
                    Panel.ZIndex="600" Visibility="Collapsed"
                    IsHitTestVisible="True"
                    MouseDown="ContactProfileOverlay_BgClick">
                <Border.Background>
                    <SolidColorBrush Color="#AA060A10"/>
                </Border.Background>
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="340" CornerRadius="20"
                        MouseDown="ContactProfileCard_Click">
                    <Border.Background>
                        <SolidColorBrush Color="#17212B"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="4" Opacity="0.7" Color="#060A10"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="32" Height="32" CornerRadius="16"
                                Background="#1E2D3D" Margin="12,12,12,0"
                                Cursor="Hand" Panel.ZIndex="10"
                                MouseDown="CloseContactProfile_Click">
                            <TextBlock Text="✕" FontSize="13" Foreground="#708499"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>


                        <StackPanel Grid.Row="0" HorizontalAlignment="Center"
                                    Margin="28,32,28,20">

                            <Border Width="90" Height="90" CornerRadius="45"
                                    HorizontalAlignment="Center" Margin="0,0,0,16"
                                    BorderThickness="3">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3390EC" Offset="0"/>
                                        <GradientStop Color="#4BA3F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border CornerRadius="43" ClipToBounds="True"
                                        Width="84" Height="84">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2B3847" Offset="0"/>
                                            <GradientStop Color="#3390EC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid Width="84" Height="84">
                                        <TextBlock x:Name="ProfileAvatarInitials"
                                                   Text="?" FontSize="30" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Image x:Name="ProfileAvatarImg"
                                               Width="84" Height="84"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Clip>
                                                <EllipseGeometry Center="42,42" RadiusX="42" RadiusY="42"/>
                                            </Image.Clip>
                                        </Image>
                                    </Grid>
                                </Border>
                            </Border>


                            <TextBlock x:Name="ProfileDisplayName"
                                       Text="" FontSize="18" FontWeight="Bold"
                                       Foreground="#F5F5F5" HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>


                            <TextBlock x:Name="ProfileHashDisplay"
                                       Text="" FontSize="12" Foreground="#3390EC"
                                       HorizontalAlignment="Center" Cursor="Hand"
                                       ToolTip="Click to copy"
                                       MouseDown="ProfileHash_Click"
                                       Margin="0,0,0,20"/>


                            <Border Height="1" Background="#242F3D" Margin="-28,0"/>
                        </StackPanel>


                        <StackPanel Grid.Row="1" Margin="28,16,28,28">
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Messages in chat"
                                           FontSize="13" Foreground="#708499"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ProfileMsgCount"
                                           Grid.Column="1" Text="…"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#F5F5F5" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Status"
                                           FontSize="13" Foreground="#708499"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ProfileStatus"
                                           Grid.Column="1" Text="…"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#F5F5F5" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>


            <Border x:Name="ToastBorder"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,34" Padding="18,11"
                    CornerRadius="14" Panel.ZIndex="999"
                    Visibility="Collapsed" IsHitTestVisible="False">
                <Border.Background>
                    <SolidColorBrush Color="#EE0E1621"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45" Color="#060A10"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✅" FontSize="15"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="ToastText" Text="" Foreground="White"
                               FontSize="13" VerticalAlignment="Center" MaxWidth="400"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
                                            Opacity="0"
                                            BorderThickness="0"
                                            Background="Transparent"/>
                                </Grid>

                                <!-- ТЕКСТ -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="MyDisplayNameLabel" Text="..." FontSize="13"
                       FontWeight="SemiBold" Foreground="#F5F5F5"
                       TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="MyHashDisplay" Text="..."
                       Foreground="#708499" FontSize="11" Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"
                       Cursor="Hand" ToolTip="Click to copy ID"
                       MouseDown="CopyMyHash_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>


                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,0,10,8">
                            <Button x:Name="TabChatsBtn" Content="💬  Chats"
                                    Style="{StaticResource TabBtnActive}"
                                    Click="TabChats_Click" Margin="0,0,4,0"/>
                            <Button x:Name="TabGroupsBtn" Content="👥  Groups"
                                    Style="{StaticResource TabBtn}"
                                    Click="TabGroups_Click"/>
                        </StackPanel>


                        <Grid x:Name="AddContactRow" Grid.Row="3" Margin="10,0,10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="10" Background="#242F3D"
                                    BorderBrush="#344657" BorderThickness="1"
                                    Margin="0,0,8,0">
                                <TextBox x:Name="NewContactHashInput"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#F5F5F5" Padding="12,0"
                                         Height="38" FontSize="12" CaretBrush="#3390EC"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" x:Name="AddBtn" Style="{StaticResource PrimaryBtn}"
                                    Width="38" Height="38" Click="AddContact_Click">
                                <TextBlock Text="+" FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Button>
                        </Grid>

                        <Grid x:Name="AddGroupRow" Grid.Row="3" Margin="10,0,10,8" Visibility="Collapsed">
                            <Button Content="＋  New Group" Style="{StaticResource PrimaryBtn}"
                                    Height="38" FontSize="13" Click="AddContact_Click"/>
                        </Grid>


                        <ListBox Grid.Row="4" x:Name="ContactsList"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ContactsList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ItemBg" Margin="5,1" Padding="10,9"
                                            CornerRadius="10" Background="Transparent" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="36" Height="36">
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#242F3D" Offset="0"/>
                                                            <GradientStop Color="#2B3847" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Initials}" FontSize="11"
                                                           FontWeight="Bold" Foreground="#5BA0D6"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Image Source="{Binding AvatarSource}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                                    </Image.Clip>
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="#F5F5F5"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           Foreground="{Binding StatusColor}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <Ellipse Width="7" Height="7"
                                                         Fill="{Binding StatusColor}"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <Border CornerRadius="9" MinWidth="18" Height="18"
                                                        Padding="4,0" VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#E53935"/>
                                                    </Border.Background>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding UnreadText}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background" Value="#1E2D3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                     Value="True">
                                            <Setter TargetName="ItemBg" Property="Background" Value="#2B5278"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>


                        <ListBox Grid.Row="4" x:Name="GroupsList"
                                 Background="Transparent" BorderThickness="0"
                                 Visibility="Collapsed"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="GroupsList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="GItemBg" Margin="5,1" Padding="10,9"
                                            CornerRadius="10" Background="Transparent" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="36" Height="36">
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#1D2B3A" Offset="0"/>
                                                            <GradientStop Color="#242F3D" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="G" FontSize="14" FontWeight="Bold"
                                                           Foreground="#3390EC"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Name}" Foreground="#F5F5F5"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding MemberCountText}" FontSize="11"
                                                           Foreground="#708499" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <Border CornerRadius="9" MinWidth="18" Height="18"
                                                        Padding="4,0" VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#E53935"/>
                                                    </Border.Background>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding UnreadText}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="GItemBg" Property="Background" Value="#1E2D3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                     Value="True">
                                            <Setter TargetName="GItemBg" Property="Background" Value="#2B5278"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>


                        <Border Grid.Row="5" BorderBrush="#242F3D" BorderThickness="0,1,0,0" Padding="12,10">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="GlobalStatusDot" Width="7" Height="7"
                                             Fill="#00C853" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="GlobalStatusText" Text="Connected"
                                               Foreground="#708499" FontSize="11" FontWeight="Medium"/>
                                </StackPanel>

                                <Grid Grid.Column="1" Margin="0,0,2,0">
                                    <Button x:Name="RequestsBellBtn"
                                            Style="{StaticResource GhostBtn}"
                                            Width="34" Height="34" FontSize="15"
                                            Click="ToggleRequests_Click"
                                            ToolTip="Contact requests">
                                        <TextBlock Text="🔔" FontSize="14"/>
                                    </Button>
                                    <Border x:Name="RequestsBadge"
                                            Visibility="Collapsed"
                                            Width="16" Height="16" CornerRadius="8"
                                            Background="#E53935"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,2,3,0"
                                            IsHitTestVisible="False">
                                        <TextBlock x:Name="RequestsBadgeText"
                                                   Text="0" FontSize="9" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Button Grid.Column="2" Content="⏻" Style="{StaticResource GhostBtn}"
                                        Width="34" Height="34" FontSize="16"
                                        Foreground="#E53935" Click="Logout_Click"
                                        Grid.ColumnSpan="2"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>


                <Border Grid.Column="1" Background="#0E1621" CornerRadius="0,24,24,0" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <Border x:Name="ChatHeaderBorder"
                                BorderBrush="#242F3D" BorderThickness="0,0,0,1"
                                Background="#17212B" CornerRadius="0,24,0,0">
                            <Grid Margin="22,0">
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="ChatStatusDot" Width="8" Height="8"
                                                 Fill="#00C853" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Visibility="Collapsed"/>
                                        <TextBlock x:Name="CurrentChatTitle" Text=""
                                                   FontSize="15" FontWeight="SemiBold" Foreground="#F5F5F5"
                                                   VerticalAlignment="Center"
                                                   Cursor="Hand"
                                                   MouseDown="ChatHeader_Click"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CurrentChatStatus" Text=""
                                               FontSize="12" Foreground="#708499" Margin="16,2,0,0"/>
                                </StackPanel>

                                <!-- КНОПКА ПЕРЕВОДА — только в личных чатах -->
                                <Border x:Name="TranslateBtn"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        Visibility="Collapsed"
                                        Padding="12,6"
                                        CornerRadius="16"
                                        MouseDown="TranslateBtn_Click"
                                        MouseEnter="TranslateBtn_MouseEnter"
                                        MouseLeave="TranslateBtn_MouseLeave">
                                    <Border.Background>
                                        <SolidColorBrush Color="#1A3390EC"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#3390EC" Opacity="0.45"/>
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>1</Border.BorderThickness>
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="60" CenterY="14"/>
                                    </Border.RenderTransform>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="文A" FontSize="13" Foreground="#3390EC"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="TranslateBtnText"
                                                   Text="Translate"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#3390EC"
                                                   VerticalAlignment="Center"/>
                                        <Border Width="1" Background="#3390EC" Opacity="0.35"
                                                Margin="8,2,8,2"/>
                                        <TextBlock Text="RU/EN"
                                                   FontSize="10" FontWeight="Medium"
                                                   Foreground="#3390EC" Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="ChatAvatarText" Visibility="Collapsed"/>
                                <Image x:Name="ChatAvatarImg" Visibility="Collapsed"/>
                            </Grid>
                        </Border>


                        <!-- ═══ ОВЕРЛЕЙ ПЕРЕВОДА ═══ -->
                        <Border x:Name="TranslateOverlay"
                                Grid.Row="1"
                                Panel.ZIndex="50"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#EE080E18" Offset="0"/>
                                    <GradientStop Color="#F00B1120" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                <!-- Большое внешнее свечение -->
                                <Ellipse x:Name="TranslateGlowOuter"
                                         Width="260" Height="260"
                                         Opacity="0.07" IsHitTestVisible="False">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#3390EC" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!-- Карточка -->
                                <Border CornerRadius="28" Padding="44,38,44,36"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#131C28" Offset="0"/>
                                            <GradientStop Color="#0E1621" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3390EC" Offset="0"/>
                                            <GradientStop Color="#1A2D45" Offset="0.5"/>
                                            <GradientStop Color="#3390EC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>1.5</Border.BorderThickness>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#3390EC" BlurRadius="40"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Border.Effect>

                                    <StackPanel HorizontalAlignment="Center">

                                        <!-- Буква B — большая и красивая -->
                                        <Grid Width="110" Height="110"
                                              HorizontalAlignment="Center" Margin="0,0,0,22">

                                            <!-- Пульсирующее свечение под буквой -->
                                            <Ellipse x:Name="TranslateGlowInner"
                                                     Width="130" Height="130"
                                                     Opacity="0.18" IsHitTestVisible="False">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#3390EC" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="0.7"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>

                                            <!-- Круглый фон буквы -->
                                            <Ellipse Width="110" Height="110">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#1A2D45" Offset="0"/>
                                                        <GradientStop Color="#0E1828" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                                <Ellipse.Stroke>
                                                    <SolidColorBrush Color="#2A3D55"/>
                                                </Ellipse.Stroke>
                                                <Ellipse.StrokeThickness>1.5</Ellipse.StrokeThickness>
                                            </Ellipse>

                                            <!-- Буква B — контур (подложка) -->
                                            <Viewbox Width="64" Height="72"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Canvas Width="60" Height="80">
                                                    <Path Fill="#1E3050"
                                                          Data="M6,4 L6,76 L34,76 Q58,76 58,60 Q58,48 46,43 Q58,38 58,22 Q58,4 34,4 Z
                                                                M16,14 L32,14 Q46,14 46,23 Q46,34 32,34 L16,34 Z
                                                                M16,46 L34,46 Q48,46 48,60 Q48,72 34,72 L16,72 Z"/>
                                                </Canvas>
                                            </Viewbox>

                                            <!-- Буква B — заполнение снизу вверх через OpacityMask + Clip на Path -->
                                            <Viewbox Width="64" Height="72"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Canvas Width="60" Height="80">
                                                    <!-- Path буквы B с Clip через геометрию самой буквы +
                                                         RectangleGeometry для анимации заполнения.
                                                         Используем CombinedGeometry: пересечение буквы и прямоугольника -->
                                                    <Path Data="M6,4 L6,76 L34,76 Q58,76 58,60 Q58,48 46,43 Q58,38 58,22 Q58,4 34,4 Z
                                                                M16,14 L32,14 Q46,14 46,23 Q46,34 32,34 L16,34 Z
                                                                M16,46 L34,46 Q48,46 48,60 Q48,72 34,72 L16,72 Z">
                                                        <Path.Fill>
                                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                                <GradientStop Color="#1A6BC4" Offset="0"/>
                                                                <GradientStop Color="#3390EC" Offset="0.5"/>
                                                                <GradientStop Color="#5AB4FF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Path.Fill>
                                                        <Path.Effect>
                                                            <DropShadowEffect Color="#3390EC" BlurRadius="18"
                                                                              ShadowDepth="0" Opacity="0.9"/>
                                                        </Path.Effect>
                                                        <Path.OpacityMask>
                                                            <VisualBrush>
                                                                <VisualBrush.Visual>
                                                                    <Rectangle Width="60" Height="80">
                                                                        <Rectangle.Fill>
                                                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                                                <GradientStop x:Name="TranslateFillStop0" Color="White" Offset="0"/>
                                                                                <GradientStop x:Name="TranslateFillStop1" Color="White" Offset="0"/>
                                                                                <GradientStop x:Name="TranslateFillStop2" Color="Transparent" Offset="0.001"/>
                                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Rectangle.Fill>
                                                                    </Rectangle>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Path.OpacityMask>
                                                    </Path>
                                                </Canvas>
                                            </Viewbox>


                                            <!-- Блик сверху -->
                                            <Ellipse Width="40" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Top"
                                                     Margin="0,14,0,0"
                                                     Opacity="0.08">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="White" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>

                                        <!-- Прогресс бар -->
                                        <Border Width="180" Height="4" CornerRadius="2"
                                                Background="#1A2D3D" Margin="0,0,0,16">
                                            <Border x:Name="TranslateProgressBar"
                                                    HorizontalAlignment="Left"
                                                    Height="4" Width="0" CornerRadius="2">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#3390EC" Offset="0"/>
                                                        <GradientStop Color="#5AC8FA" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#3390EC" BlurRadius="8"
                                                                      ShadowDepth="0" Opacity="0.9"/>
                                                </Border.Effect>
                                            </Border>
                                        </Border>

                                        <!-- Текст -->
                                        <TextBlock x:Name="TranslateOverlayText"
                                                   Text="Translating…"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="#F0F5FF"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock x:Name="TranslateOverlayCount"
                                                   Text=""
                                                   FontSize="12" FontWeight="Normal"
                                                   Foreground="#4A6580"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="ChatScroll" Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0"
                                      ScrollChanged="ChatScroll_ScrollChanged"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      CanContentScroll="False">
                            <ScrollViewer.RenderTransform>

<Window x:Class="server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bizzard" Height="760" Width="1180"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.EdgeMode="Aliased"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>


        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                        RenderTransformOrigin="0.5,0.5">

                            <Border.Background>
                                <SolidColorBrush Color="#3390EC"/>
                            </Border.Background>

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>


                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#4BA3F5"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.022" ScaleY="1.022"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>


                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#3390EC"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>


                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#2878C7"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>


                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.42"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8696A8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.018" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.018" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.22"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.22"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Bd" Property="Background" Value="#1D2B3A"/>
                                <Setter Property="Foreground" Value="#E4E9F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#253545"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TrafficClose" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FF5F57"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="El" Fill="{TemplateBinding Background}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="El" Property="Fill" Value="#FF3B30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrafficMin" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FEBC2E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="El" Fill="{TemplateBinding Background}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="El" Property="Fill" Value="#E5A800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrafficRestore" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#28C840"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="El" Fill="{TemplateBinding Background}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.18" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="El"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="El" Property="Fill" Value="#1AAD30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#708499"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.03" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.03" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Bd" Property="Background" Value="#1A2E3F"/>
                                <Setter Property="Foreground" Value="#E4E9F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
            <Setter Property="Background" Value="#1A3390EC"/>
            <Setter Property="Foreground" Value="#3390EC"/>
        </Style>

        <Style x:Key="TabBtnAlt" TargetType="Button" BasedOn="{StaticResource TabBtn}"/>


        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2A394D" CornerRadius="2.5" Margin="0,2"
                                                        Opacity="0.7"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#3390EC" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Fill="White">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#3390EC" BlurRadius="10"
                                                                              ShadowDepth="0" Opacity="0.55"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#242F3D" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Border x:Name="RootBorder" CornerRadius="24"
            Background="#0E1621"
            BorderBrush="#2A394D" BorderThickness="1"
            ClipToBounds="True">
        <Grid>


            <Border x:Name="AuthScreen" Panel.ZIndex="20" Visibility="Visible" CornerRadius="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#1A2538" Offset="0"/>
                        <GradientStop Color="#0E1621" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>

                    <Ellipse Width="520" Height="340" VerticalAlignment="Top"
                             HorizontalAlignment="Center" Margin="0,-170,0,0"
                             Opacity="0.08" IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3390EC" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Top" Margin="20,18,0,0">
                        <Button Style="{StaticResource TrafficClose}" Click="CloseApp_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource TrafficMin}" Click="MinimizeApp_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource TrafficRestore}" Click="RestoreWindow_Click"/>
                    </StackPanel>


                    <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">


                        <Border x:Name="LogoBorder" Width="72" Height="72" CornerRadius="22"
                                HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3390EC" Offset="0"/>
                                    <GradientStop Color="#5AC8FA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#3390EC" BlurRadius="28" ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                            <TextBlock Text="B" FontSize="38" FontWeight="Black" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,0,2,0"/>
                        </Border>

                        <TextBlock Text="Bizzard" FontSize="30" FontWeight="Bold"
                                   Foreground="#F5F5F5" HorizontalAlignment="Center"/>
                        <TextBlock Text="Encrypted private network" Foreground="#708499"
                                   HorizontalAlignment="Center" FontSize="14" Margin="0,5,0,38"/>


                        <TextBlock Text="E M A I L" Foreground="#8696A8" FontSize="10"
                                   FontWeight="Bold" Margin="4,0,0,8"/>
                        <Border CornerRadius="12" Background="#1A2538" Margin="0,0,0,6"
                                BorderThickness="1" BorderBrush="#344657">
                            <TextBox x:Name="EmailInput" Background="Transparent" BorderThickness="0"
                                     Foreground="#F5F5F5" Padding="14,12" CaretBrush="#3390EC"
                                     VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                        <TextBlock x:Name="EmailError" Text="" Foreground="#E53935"
                                   FontSize="11" Margin="4,0,0,12" Visibility="Collapsed"/>


                        <TextBlock Text="P A S S W O R D" Foreground="#8696A8" FontSize="10"
                                   FontWeight="Bold" Margin="4,0,0,8"/>
                        <Border CornerRadius="12" Background="#1A2538" Margin="0,0,0,6"
                                BorderThickness="1" BorderBrush="#344657">
                            <PasswordBox x:Name="PasswordInput" Background="Transparent" BorderThickness="0"
                                         Foreground="#F5F5F5" Padding="14,12"
                                         VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                        <TextBlock x:Name="PasswordError" Text="" Foreground="#E53935"
                                   FontSize="11" Margin="4,0,0,20" Visibility="Collapsed"/>


                        <Button Content="Sign In" Style="{StaticResource PrimaryBtn}"
                                Height="50" FontSize="15" Click="Login_Click" Margin="0,0,0,12"/>
                        <Button Content="Create new account" Style="{StaticResource GhostBtn}"
                                Height="44" Foreground="#708499" Click="Register_Click"/>
                    </StackPanel>
                </Grid>
            </Border>


            <Border x:Name="VerifyScreen" Panel.ZIndex="21" Visibility="Collapsed" CornerRadius="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#1A2538" Offset="0"/>
                        <GradientStop Color="#0E1621" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="520" Height="340" VerticalAlignment="Top"
                             HorizontalAlignment="Center" Margin="0,-170,0,0"
                             Opacity="0.06" IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3390EC" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Top" Margin="20,18,0,0">
                        <Button Style="{StaticResource TrafficClose}" Click="CloseApp_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource TrafficMin}" Click="MinimizeApp_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource TrafficRestore}" Click="RestoreWindow_Click"/>
                    </StackPanel>

                    <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✉️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                        <TextBlock Text="Check your email" FontSize="26" FontWeight="Bold"
                                   Foreground="#F5F5F5" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="VerifyEmailHint" Text="" Foreground="#708499"
                                   FontSize="13" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,8,0,34"/>

                        <TextBlock Text="V E R I F I C A T I O N   C O D E" Foreground="#8696A8" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <Border CornerRadius="12" Background="#1A2538"
                                BorderThickness="1" BorderBrush="#344657">
                            <TextBox x:Name="VerifyCodeInput" Background="Transparent" BorderThickness="0"
                                     Foreground="#F5F5F5" Padding="14,14" CaretBrush="#3390EC"
                                     VerticalContentAlignment="Center" FontSize="24"
                                     FontWeight="Bold" TextAlignment="Center" MaxLength="6"/>
                        </Border>
                        <TextBlock x:Name="VerifyError" Text="" Foreground="#E53935"
                                   FontSize="11" Margin="0,8,0,20" Visibility="Collapsed"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Confirm Email" Style="{StaticResource PrimaryBtn}"
                                Height="50" FontSize="15" Click="ConfirmEmail_Click" Margin="0,0,0,12"/>
                        <Button Content="← Back to sign in" Style="{StaticResource GhostBtn}"
                                Height="42" Foreground="#708499" Click="BackToLogin_Click"/>
                    </StackPanel>
                </Grid>
            </Border>


            <Grid x:Name="MainScreen" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <Border Background="#17212B" BorderBrush="#242F3D" BorderThickness="0,0,1,0"
                        CornerRadius="24,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="52"/>
                        </Grid.RowDefinitions>


                        <Grid Margin="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource TrafficClose}" Click="CloseApp_Click" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource TrafficMin}" Click="MinimizeApp_Click" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource TrafficRestore}" Click="RestoreWindow_Click" Margin="0,0,14,0"/>
                                <TextBlock Text="Bizzard" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E4E9F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>


                        <Border Grid.Row="1" Margin="10,0,10,8" Padding="10,10"
        Background="Transparent" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- АВАТАР -->
                                <Grid Width="44" Height="44" Margin="0,0,10,0">
                                    <Border CornerRadius="22"
                                            BorderThickness="2"
                                            BorderBrush="#3390EC"
                                            Width="44" Height="44">
                                        <Border CornerRadius="20"
                                                Width="40" Height="40"
                                                ClipToBounds="True">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3390EC" Offset="0"/>
                                                    <GradientStop Color="#4BA3F5" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid Width="40" Height="40">
                                                <!-- ИНИЦИАЛЫ -->
                                                <TextBlock x:Name="MyAvatarInitialsBlock"
                                                           Text="ME"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <!-- КАРТИНКА -->
                                                <Image x:Name="MyAvatarImg"
                                                       Width="40" Height="40"
                                                       Stretch="UniformToFill"
                                                       Visibility="Collapsed"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                        </Border>
                                    </Border>

                                    <!-- КНОПКА — открывает настройки -->
